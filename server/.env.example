# Server Environment Variables
PORT=5000
NODE_ENV=development

# REQUIRED on Render (Dashboard -> Environment):
# mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/interviewiq?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/interviewiq

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

GEMINI_API_KEY=your-gemini-api-key

# Frontend URL for CORS (no trailing slash)
CLIENT_URL=http://localhost:5173
# Optional extra origins: CORS_ORIGINS=https://www.example.com,https://staging.example.com

MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads
